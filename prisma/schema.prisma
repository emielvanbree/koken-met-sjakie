generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  diaryEntries      DiaryEntry[]
  shoppingLists     ShoppingList[]
  gamification      GamificationProgress?
  savedRecipes      SavedRecipe[]
  techniqueCount    Int @default(0)
}

model DiaryEntry {
  id          String   @id @default(cuid())
  userId      String
  dishName    String
  cuisine     String   @default("Overig")
  date        DateTime @default(now())
  cookDuration Int     @default(0)
  difficulty  Int      @default(1)
  servings    Int      @default(2)
  rating      Int?
  emoji       String?
  notes       String?
  imagePath   String?
  badgesEarned String  @default("[]")
  recipeJson  String   @default("{}")
  usedPanic   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  items     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedRecipe {
  id         String   @id @default(cuid())
  userId     String
  name       String
  recipeJson String
  savedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

