# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Database (Railway voegt dit automatisch toe als je een volume koppelt)
DATABASE_URL=file:/app/data/kms.db

# JWT Secret (genereer een willekeurige string, bijv. via: openssl rand -base64 32)
JWT_SECRET=verander-dit-naar-een-lange-willekeurige-string

# Node environment
NODE_ENV=production
